@page
@model Language_Learning_App.Pages.Flashcards.EditModel

@{
    ViewData["Title"] = "Edit Flashcard";
}

<h1>Edit Flashcard</h1>

<h4>Flashcard Details</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <input type="hidden" asp-for="Flashcard.FlashcardID" />
            <input type="hidden" asp-for="Flashcard.DeckID" />

            <div class="form-group">
                <label>Front Text</label>
                <input asp-for="Flashcard.FrontText" class="form-control" />
            </div>

            <div class="form-group">
                <label>Back Text</label>
                <input asp-for="Flashcard.BackText" class="form-control" />
            </div>

            <div class="form-group mt-3">
                <label asp-for="TagString" class="control-label">Tags (separated by commas)</label>
                <input asp-for="TagString" class="form-control" placeholder="e.g. Chemistry, Acids, Midterm" />
                <span class="text-muted small">Separate tags with a comma. New tags will be created automatically.</span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save Changes" class="btn btn-primary" />
                <a asp-page="./Index" asp-route-deckId="@Model.Flashcard.DeckID" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}