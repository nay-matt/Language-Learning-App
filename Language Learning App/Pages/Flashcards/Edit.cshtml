@page
@model Language_Learning_App.Pages.Flashcards.EditModel

@{
    ViewData["Title"] = "Edit Flashcard";
}

<h1>Edit Flashcard</h1>

<h4>Flashcard Details</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <input type="hidden" asp-for="Flashcard.FlashcardID" />
            <input type="hidden" asp-for="Flashcard.DeckID" />

            <div class="form-group mb-3">
                <label asp-for="Flashcard.FrontText" class="control-label font-weight-bold"></label>
                <input asp-for="Flashcard.FrontText" class="form-control" placeholder="Enter front text (e.g., Bonjour)" />
                <span asp-validation-for="Flashcard.FrontText" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Flashcard.BackText" class="control-label font-weight-bold"></label>
                <input asp-for="Flashcard.BackText" class="form-control" placeholder="Enter translation (e.g., Hello)" />
                <span asp-validation-for="Flashcard.BackText" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Flashcard.Difficulty" class="control-label"></label>
                <select asp-for="Flashcard.Difficulty" class="form-control">
                    <option value="1">Easy</option>
                    <option value="2">Medium</option>
                    <option value="3">Hard</option>
                </select>
                <span asp-validation-for="Flashcard.Difficulty" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save Changes" class="btn btn-primary" />
                <a asp-page="./Index" asp-route-deckId="@Model.Flashcard.DeckID" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}